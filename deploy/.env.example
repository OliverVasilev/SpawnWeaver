# SpawnWeaver production environment — copy to deploy/.env and fill in.
# deploy/.env is git-ignored (never commit real secrets).

# Public domain (DNS A record must point at this server). Used for TLS + email + SDK links.
DOMAIN=spawnweaver.dev

# Email for Let's Encrypt expiry notices.
ACME_EMAIL=you@spawnweaver.dev

# PostgreSQL password (any strong value; the DB is created with it on first run).
POSTGRES_PASSWORD=change-me-to-a-long-random-string

# Resend transactional email. Get a key at https://resend.com and verify your sending domain.
# Leave EMAIL__RESEND__APIKEY empty to disable real email (falls back to the dev/logging sender,
# which auto-verifies accounts — handy before your domain is verified in Resend).
EMAIL__RESEND__APIKEY=
# Once your domain is verified in Resend, use an address on it, e.g. noreply@spawnweaver.dev.
# Before that, Resend's onboarding@resend.dev can only deliver to your own Resend account email.
EMAIL__FROMADDRESS=onboarding@resend.dev
EMAIL__FROMNAME=SpawnWeaver
