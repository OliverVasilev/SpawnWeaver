@page "/dashboard/onboarding"
@inject DashboardUser User

<div class="page-head">
    <h2>Create a project</h2>
</div>

@if (!User.IsAuthenticated)
{
    <div class="card">
        <div class="banner banner-warn">
            <span>🔒</span>
            <span>You need an account to create a project.
                <a href="/dashboard/signin">Sign in</a> or
                <a href="/dashboard/signup">create one</a>.</span>
        </div>
    </div>
}
else
{
    <div class="card" id="ob-form">
        <div class="section-title" style="margin-top:0">New project</div>
        <p class="muted" style="margin-top:0">
            Give it a name and you'll get your keys instantly. You can view details and regenerate
            keys anytime from the project page.
        </p>

        <label class="field-label" for="ob-name">Project name</label>
        <input id="ob-name" class="field" type="text" placeholder="My Game" autocomplete="off" />

        <label class="field-label" for="ob-env">Environment</label>
        <select id="ob-env" class="field" style="max-width:240px">
            <option value="Development">Development</option>
            <option value="Production">Production</option>
        </select>

        <div style="margin-top:18px">
            <button class="btn btn-primary" type="button" onclick="swCreateProjectOnboarding()">Create project</button>
            <span id="ob-status"></span>
        </div>
    </div>

    <div id="ob-result" class="card hidden"></div>
}
