<DocsPage Slug="index">
    <h1>SpawnWeaver docs</h1>
    <p class="lead">
        Everything you need to add online multiplayer to your Godot game — rooms, lobbies,
        matchmaking, state sync, and persistence — with a Godot-native SDK and no backend code.
    </p>

    <h2>Start here</h2>
    <div class="hub-grid">
        <a class="hub-card" href="/dashboard/docs/getting-started">
            <div class="hub-icon">⚡</div>
            <div class="hub-title">Quickstart</div>
            <div class="hub-desc">Account → project → SDK → two players connected.</div>
        </a>
        <a class="hub-card" href="/dashboard/docs/concepts">
            <div class="hub-icon">🧩</div>
            <div class="hub-title">Core concepts</div>
            <div class="hub-desc">Projects, players, rooms, lobbies, state, persistence.</div>
        </a>
        <a class="hub-card" href="/dashboard/docs/hosting">
            <div class="hub-icon">🚀</div>
            <div class="hub-title">Host on AWS Lightsail</div>
            <div class="hub-desc">Your own backend on a domain with HTTPS in ~15 minutes.</div>
        </a>
        <a class="hub-card" href="/dashboard/docs/tutorial-2d-shooter">
            <div class="hub-icon">🎮</div>
            <div class="hub-title">Build a shooter</div>
            <div class="hub-desc">Full 2D &amp; 3D multiplayer arena shooters, step by step.</div>
        </a>
        <a class="hub-card" href="/dashboard/docs/sdk-reference">
