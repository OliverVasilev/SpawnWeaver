@page "/dashboard/docs/limits"

<div class="page-head"><h2>Limits</h2></div>

<DocsPage Slug="limits">
    <h1>Limits</h1>
    <p class="lead">The limits the service enforces today. If you hit one, the SDK surfaces a clear error.</p>

    <table>
        <thead><tr><th>Limit</th><th>Default</th></tr></thead>
        <tbody>
            <tr><td>Message size</td><td>16&nbsp;KB</td></tr>
            <tr><td>Messages / sec per player</td><td>20 (burst 40)</td></tr>
            <tr><td>Entities / room</td><td>50</td></tr>
            <tr><td>Entity state size</td><td>4&nbsp;KB</td></tr>
            <tr><td>Room state size</td><td>16&nbsp;KB</td></tr>
            <tr><td>State updates / sec per player</td><td>10</td></tr>
            <tr><td>Saved value size</td><td>64&nbsp;KB</td></tr>
            <tr><td>Saved keys / player</td><td>100</td></tr>
        </tbody>
    </table>

    <div class="docs-next">
