@page "/dashboard/projects/{ProjectId}"
@using Platform.Application.Projects
@using Platform.Application.Storage
@using Platform.Realtime.Diagnostics
@using Microsoft.Extensions.Options
@inject ProjectService ProjectSvc
@inject DashboardUser User
@inject IOptions<StorageOptions> StorageOpts
@inject RealtimeDiagnostics Diagnostics

<div class="page-head">
    <h2>@(_project?.Name ?? "Project")</h2>
    <a class="btn btn-secondary btn-sm" href="/dashboard/projects">← All projects</a>
</div>

@if (_project is null)
{
    <div class="card">
        <div class="empty">Project not found, or it isn't in your workspace.</div>
    </div>
}
else
{
    <div class="card">
        <div class="section-title" style="margin-top:0">Details</div>
        <div class="kv"><div class="kv-label">Project ID</div><div class="mono">@_project.Id</div></div>
        <div class="kv"><div class="kv-label">Name</div><div>@_project.Name</div></div>
        <div class="kv"><div class="kv-label">Slug</div><div class="mono">@_project.Slug</div></div>
        <div class="kv">
            <div class="kv-label">Status</div>
            <div>
                @if (_project.IsActive)
                {
                    <span class="badge badge-green">active</span>
                }
                else
                {
                    <span class="badge badge-dim">inactive</span>
                }
            </div>
        </div>
        <div class="kv"><div class="kv-label">Environment</div><div>@_project.Environment</div></div>
        <div class="kv"><div class="kv-label">Workspace</div><div>@(_orgName ?? "—")</div></div>
        <div class="kv"><div class="kv-label">Created (UTC)</div><div class="muted">@_project.CreatedAtUtc.ToString("u")</div></div>
    </div>

    <div class="card">
        <div class="section-title" style="margin-top:0">API keys</div>

        <div class="key-row">
            <div class="key-label">Public key — safe to ship in your game client</div>
            <div class="key-box">
                <span class="key-value">@_project.PublicKey</span>
                <button class="copy-btn" type="button" onclick="swCopy('@_project.PublicKey', this)">Copy</button>
            </div>
        </div>

        <p class="muted" style="margin:6px 0 0">
            The <strong>secret key</strong> (server-side only) is stored as a hash and can't be shown
            again. Generate a new one if you've lost it or it may be exposed.
        </p>

        <div class="create-row" style="margin-top:14px">
            <button class="btn btn-primary" type="button" onclick="swRotateSecret('@_project.Id')">Generate new secret key</button>
            <button class="btn btn-ghost" type="button" onclick="swRotatePublic('@_project.Id')">Rotate public key</button>
            <span id="pk-status"></span>
        </div>
        <div id="pk-secret-result" class="hidden" style="margin-top:14px"></div>
        <div id="pk-public-result" class="hidden" style="margin-top:14px"></div>

        <div class="banner banner-warn" style="margin-top:16px">
            <span>⚠</span>
            <span>Rotating the <strong>public key</strong> disconnects any game already shipped with
                the old key. Only do it if the key leaked or before you've distributed your game.</span>
        </div>
    </div>

    <div class="card">
        <div class="section-title" style="margin-top:0">Plan &amp; limits</div>
        <div class="stat-grid" style="margin-bottom:14px">
            <div class="card stat">
                <div class="value cyan">@_activeConnections</div>
                <div class="label">Connections now</div>
            </div>
            <div class="card stat">
                <div class="value violet">@_activeRooms</div>
                <div class="label">Active rooms</div>
            </div>
        </div>
        <div class="kv"><div class="kv-label">Plan</div><div><span class="badge badge-cyan">Free</span></div></div>
        <div class="kv"><div class="kv-label">Storage value size</div><div>@FormatBytes(_storage.MaxValueBytes) per key</div></div>
        <div class="kv"><div class="kv-label">Storage keys</div><div>@_storage.MaxKeysPerPlayer per player</div></div>
        <div class="kv"><div class="kv-label">Storage key length</div><div>@_storage.MaxKeyLength chars</div></div>
        <p class="muted" style="margin:8px 0 0">
            These are the limits the API enforces. See <a href="/dashboard/docs/limits">Limits</a>
            for the full table and what happens when a limit is hit.
        </p>
    </div>

    <div class="card">
        <div class="section-title" style="margin-top:0">Connect from Godot</div>
        <pre>MultiplayerService.configure("@_project.PublicKey")
MultiplayerService.connect_to_server("wss://spawnweaver.dev/connect")</pre>
        <p class="muted" style="margin-bottom:0">
            Or save the key + URL in the SpawnWeaver editor dock and call
            <code>MultiplayerService.connect_using_config()</code>.
        </p>
    </div>
}

@code {
    [Parameter] public string ProjectId { get; set; } = "";

    private Platform.Domain.Projects.Project? _project;
    private string? _orgName;
    private StorageOptions _storage = new();
    private int _activeConnections;
    private int _activeRooms;

    protected override async Task OnInitializedAsync()
    {
        var org = await User.GetOrganizationAsync();
        if (org is null)
        {
            return;
        }

        var project = await ProjectSvc.GetAsync(ProjectId);
        // Only surface projects that belong to the signed-in user's workspace.
        if (project is not null && project.OrganizationId == org.Id)
        {
            _project = project;
            _orgName = org.Name;
            _storage = StorageOpts.Value;
            _activeConnections = Diagnostics.GetConnections().Count(c => c.ProjectId == project.Id);
            _activeRooms = Diagnostics.GetRooms().Count(r => r.ProjectId == project.Id);
        }
    }

    private static string FormatBytes(long bytes) =>
        bytes >= 1024 ? $"{bytes / 1024.0:0.#} KB" : $"{bytes} B";
}
